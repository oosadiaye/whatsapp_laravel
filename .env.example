# Local dev seed credentials (DatabaseSeeder creates this user):
#   email:    admin@blastiq.com
#   password: password
# Change immediately after first login in any non-local environment.

APP_NAME=BlastIQ
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://yourdomain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=blastiq
DB_USERNAME=blastiq
DB_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb

# Reverb (Phase 17 inbound call browser answer)
REVERB_APP_ID=blastiq
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${APP_URL_HOST:-localhost}"
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https

# ── WebRTC / voice ────────────────────────────────────────────────────────
# Comma-separated STUN URL list passed to RTCPeerConnection. Default works
# for most networks; Phase 19b will introduce TURN for restrictive NATs.
VITE_STUN_URLS="stun:stun.l.google.com:19302"
# MOS calibration weights (see config/voice.php for tuning guidance).
# Override only if you have call-quality data showing the defaults
# are mismatched against subjective customer experience.
# VOICE_MOS_PACKET_LOSS_WEIGHT=4.0
# VOICE_MOS_JITTER_WEIGHT_PER_MS=0.08
# VOICE_MOS_RTT_WEIGHT_PER_MS=0.032

# Call recording + AI analysis (Call Workspace). OFF by default — recording
# calls has consent/retention obligations. Set to true only after you show a
# "this call may be recorded" notice and have a retention policy.
VOICE_CALL_RECORDING_ENABLED=false
# VOICE_RECORDING_MAX_KB=25600
# Delete recording audio older than N days (transcript is kept). 0 = keep forever.
# VOICE_RECORDING_RETENTION_DAYS=0
# Google Gemini transcribes + summarises the recording. Get a key at
# https://aistudio.google.com/apikey — leave blank to keep the AI panel dormant.
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
# Optional: path to ffmpeg. Chrome records webm/opus which Gemini won't accept;
# if ffmpeg is present it's remuxed to ogg first. Skipped gracefully if absent.
# FFMPEG_PATH=ffmpeg

FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@blastiq.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# WhatsApp Cloud API credentials are stored per-instance in the database
# (encrypted at rest via APP_KEY). No global API tokens needed in .env.
